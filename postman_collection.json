{
  "info": {
    "name": "Backend Challenge - Workflow API",
    "description": "Postman collection to test all workflow scenarios for the backend coding challenge",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "workflowId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Create Workflow",
      "item": [
        {
          "name": "1.1 Create Workflow - Valid Request",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 202', function () {",
                  "    pm.response.to.have.status(202);",
                  "});",
                  "",
                  "pm.test('Response has workflowId', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('workflowId');",
                  "    pm.collectionVariables.set('workflowId', jsonData.workflowId);",
                  "});",
                  "",
                  "pm.test('Response has success message', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include('Workflow created');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"clientId\": \"client123\",\n    \"geoJson\": {\n        \"type\": \"Polygon\",\n        \"coordinates\": [\n            [\n                [-63.624885020050996, -10.311050368263523],\n                [-63.624885020050996, -10.367865108370523],\n                [-63.61278302732815, -10.367865108370523],\n                [-63.61278302732815, -10.311050368263523],\n                [-63.624885020050996, -10.311050368263523]\n            ]\n        ]\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/analysis",
              "host": ["{{baseUrl}}"],
              "path": ["analysis"]
            },
            "description": "Creates a new workflow with polygon GeoJSON. This will create 4 tasks:\n1. polygonArea - Calculate area\n2. analysis - Determine country\n3. report - Aggregate results\n4. notification - Send notification"
          },
          "response": []
        },
        {
          "name": "1.2 Create Workflow - Missing clientId (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error message mentions clientId', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include('clientId');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"geoJson\": {\n        \"type\": \"Polygon\",\n        \"coordinates\": []\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/analysis",
              "host": ["{{baseUrl}}"],
              "path": ["analysis"]
            },
            "description": "Tests validation - should return 400 when clientId is missing"
          },
          "response": []
        },
