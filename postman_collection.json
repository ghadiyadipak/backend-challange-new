            "body": {
              "mode": "raw",
              "raw": "{\n    \"clientId\": \"client-feature\",\n    \"geoJson\": {\n        \"type\": \"Feature\",\n        \"properties\": {},\n        \"geometry\": {\n            \"type\": \"Polygon\",\n            \"coordinates\": [\n                [\n                    [-63.624885, -10.311050],\n                    [-63.624885, -10.367865],\n                    [-63.612783, -10.367865],\n                    [-63.612783, -10.311050],\n                    [-63.624885, -10.311050]\n                ]\n            ]\n        }\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/analysis",
