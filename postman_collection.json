            "body": {
              "mode": "raw",
              "raw": "{\n    \"clientId\": \"test-client\",\n    \"geoJson\": {\n        \"type\": \"Point\",\n        \"coordinates\": [0, 0]\n    }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/analysis",
              "host": ["{{baseUrl}}"],
              "path": ["analysis"]
            },
            "description": "Tests validation - should return 400 for Point geometry (only Polygon/MultiPolygon/Feature/FeatureCollection allowed)"
          },
          "response": []
        },
        {
          "name": "1.5 Create Workflow - Feature GeoJSON",
          "event": [
            {
              "listen": "test",
              "script": {
